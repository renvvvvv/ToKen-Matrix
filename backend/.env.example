# Token 母体 - 后端环境变量配置
# ⚠️ 不要将此文件提交到 Git 仓库
# 修复 P0-1: API Key 从环境变量读取，不再硬编码

# ==================== LLM 配置 ====================
# MiniMax 兼容 OpenAI 协议
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7-highspeed
LLM_TIMEOUT=60.0

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENV=development

# ==================== CORS 配置（白名单） ====================
# 修复 P0-3: 不再 allow_origins=*，改为白名单
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# ==================== 飞书 / 智谱（可选） ====================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
ZHIPU_API_KEY=
