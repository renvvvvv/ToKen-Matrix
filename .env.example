# Token 母体 - 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改

# ==================== 应用设置 ====================
ENV=development
DEBUG=false

# ==================== 服务器设置 ====================
HOST=0.0.0.0
PORT=8000

# ==================== 前端配置 ====================
REACT_APP_API_URL=http://localhost:8000

# ==================== 数据库配置 ====================
# 示例：postgresql://user:password@localhost:5432/tokenmatrix
DATABASE_URL=postgresql://user:pass@localhost/tokenmatrix

# ==================== 外部 API 配置 ====================

# 智谱 AI (Zhipu) API 配置
# 获取地址：https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_api_key_here

# 飞书 (Feishu) 应用配置
# 文档：https://open.feishu.cn
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here

# ==================== 系统路径配置 ====================
HERMES_SCENARIO_PATH=/app/hermes/scenarios

# ==================== CORS 配置 ====================
# 多个源用逗号分隔
CORS_ORIGINS=*

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== Redis 配置（可选） ====================
REDIS_URL=redis://localhost:6379/0

# ==================== 其他配置 ====================
API_KEY=dev-key-123
APP_NAME=Token 母体
APP_VERSION=0.1.0
